# Backend (Render)
DATABASE_URL=postgresql://user:password@host:5432/polla_infinito
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
TURNSTILE_SECRET_KEY=your-cloudflare-turnstile-secret
CORS_ORIGIN=http://localhost:5173
PORT=3001
NODE_ENV=development
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# Football API (API-Football / api-sports.io) - resultados en vivo
API_FOOTBALL_KEY=
API_FOOTBALL_URL=https://v3.football.api-sports.io
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# Frontend (Netlify)
VITE_API_URL=http://localhost:3001/api
VITE_TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key
